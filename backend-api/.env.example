APP_NAME="Sistem Sekolah"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.niswa.online

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_sekolah
DB_USERNAME=root
DB_PASSWORD=

# ─── CORS & Session (Penting untuk Production) ───────────────────────────────
FRONTEND_URL=https://niswa.online
SANCTUM_STATEFUL_DOMAINS=niswa.online
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.niswa.online

# ─── Cache & Queue ────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ─── Mail (Opsional) ──────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@niswa.online"
MAIL_FROM_NAME="${APP_NAME}"
